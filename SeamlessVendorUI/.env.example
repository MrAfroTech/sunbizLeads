# Copy to .env.local and fill in. Used by /api/book-maurice-calendar (Schedule a Demo → Teams).

# Microsoft Graph – required for Teams/Outlook booking
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# Calendar owner (events created on this user's calendar; receives Teams link)
MAURICE_SANDERS_EMAIL=

# Optional: Brevo for confirmation email (if unset, Graph sendMail is used)
# BREVO_API_KEY=
# BREVO_SENDER_EMAIL=team@ezdrink.us
# BREVO_SENDER_NAME=Seamlessly
