# Development Environment Configuration
NODE_ENV=development
REACT_APP_NODE_ENV=development

# Google Maps Configuration
REACT_APP_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
REACT_APP_DEMO_MODE=true
REACT_APP_ENABLE_CONTINUOUS_TRACKING=false

# Stripe Configuration - Test Environment Only
REACT_APP_STRIPE_TEST_PUBLISHABLE_KEY=pk_test_your_stripe_test_publishable_key_here
STRIPE_TEST_SECRET_KEY=sk_test_your_stripe_test_secret_key_here
STRIPE_TEST_WEBHOOK_SECRET=whsec_your_stripe_test_webhook_secret_here
REACT_APP_STRIPE_ENVIRONMENT=test

# Square Configuration - Sandbox Environment
REACT_APP_SQUARE_CLIENT_ID=your_square_sandbox_client_id_here
SQUARE_CLIENT_SECRET=your_square_sandbox_client_secret_here
SQUARE_ACCESS_TOKEN=your_square_sandbox_access_token_here

