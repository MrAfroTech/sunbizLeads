# Klaviyo Configuration - Development Lists
KLAVIYO_PRIVATE_API_KEY=pk_your_klaviyo_private_api_key_here
KLAVIYO_LIST_ID=your_klaviyo_dev_list_id_here
KLAVIYO_CLIENT_LIST_ID=your_klaviyo_dev_vendor_client_list_id_here

# Frontend URL - Development (Local)
FRONTEND_URL=http://localhost:3000
REACT_APP_API_BASE_URL=http://localhost:5000

# Database Configuration - Development (Local)
DATABASE_URL=postgres://dev_user:dev_password@localhost:5432/seamless_dev

# AWS Configuration - Development
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_dev_aws_access_key
AWS_SECRET_ACCESS_KEY=your_dev_aws_secret_key

# Email Configuration - Development
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_dev_email@gmail.com
SMTP_PASS=your_dev_app_password_here

# Klaviyo Template IDs - Development
KLAVIYO_WELCOME_EMAIL_TEMPLATE_ID=dev_welcome_vendor_email
KLAVIYO_WELCOME_SMS_TEMPLATE_ID=dev_welcome_vendor_sms

# Lambda Function Configuration
ALLOWED_ORIGINS=https://seamlessly.us,https://seamless-client-maurice-sanders-projects.vercel.app,http://localhost:3000,http://localhost:5000

# NCR Configuration - Development (Sandbox)
NCR_API_BASE_URL=https://gateway-staging.ncrcloud.com
NCR_TOKEN_URL=https://gateway-staging.ncrcloud.com/oauth/token

# TouchBistro Configuration - Development (Sandbox)
TOUCHBISTRO_API_BASE_URL=https://sandbox.touchbistro.com/v1
TOUCHBISTRO_ENVIRONMENT=sandbox

# Toast Configuration - Development (Sandbox)
TOAST_ENVIRONMENT=sandbox

# PayPal Configuration - Development (Sandbox)
#PAYPAL_ENVIRONMENT=sandbox

# Shopify Configuration - Development (Sandbox)
SHOPIFY_ENVIRONMENT=sandbox

# SumUp Configuration - Development (Sandbox)
SUMUP_ENVIRONMENT=sandbox

# Development-Specific Settings
REACT_APP_DEBUG_MODE=true
REACT_APP_LOG_LEVEL=debug
REACT_APP_ENABLE_HOT_RELOAD=true
REACT_APP_ENABLE_MOCK_DATA=true
