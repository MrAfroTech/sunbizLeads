# Copy to .env.local and fill in. Used by /api/book-maurice-calendar (Schedule a Demo → Teams).

# Supabase — journey tables, scan_and_scale_click_events funnel, brevo_contacts (same project as scan-scale-funnel / playwrightAutomation).
# Vercel serverless /api/log-site-event uses the same vars (or SUPABASE_SCAN_AND_SCALE_* aliases).
# Fallback order in code: *_SALES_MASTERY, then VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY (or REACT_APP_SUPABASE_URL / REACT_APP_SUPABASE_ANON_KEY).
# VITE_SUPABASE_URL_SALES_MASTERY=https://YOUR_PROJECT_REF.supabase.co
# VITE_SUPABASE_ANON_KEY_SALES_MASTERY=
# Create React App — REACT_APP_* is inlined into the bundle:
REACT_APP_SUPABASE_URL_SALES_MASTERY=https://YOUR_PROJECT_REF.supabase.co
REACT_APP_SUPABASE_ANON_KEY_SALES_MASTERY=
# Optional same-project aliases (e.g. match salesMastery/playwrightAutomation/scripts/.env):
# REACT_APP_SUPABASE_URL=
# REACT_APP_SUPABASE_ANON_KEY=
# Optional aliases for /api/log-site-event only:
# SUPABASE_SCAN_AND_SCALE_URL=
# SUPABASE_SCAN_AND_SCALE_ANON_KEY=

# Microsoft Graph – required for Teams/Outlook booking
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# Calendar owner (events created on this user's calendar; receives Teams link)
MAURICE_SANDERS_EMAIL=

# Optional: Brevo for confirmation email (if unset, Graph sendMail is used)
# BREVO_API_KEY=
# BREVO_SENDER_EMAIL=team@ezdrink.us
# BREVO_SENDER_NAME=Seamlessly

# Stripe — Calculator Plus ($17) hosted Checkout
# Create a $17 one-time Price in Stripe Dashboard, then set the Price ID (price_...).
STRIPE_TEST_SECRET_KEY=
STRIPE_LIVE_SECRET_KEY=
STRIPE_PRICE_CALCULATOR_PLUS=
