# ============================================
# It'll Happen Boyz Summer Showcase - Config
# ============================================

# --- Client identity ---
APP_NAME=It'll Happen Boyz Summer Showcase
ORGANIZER_NAME=It'll Happen Boyz Summer Showcase
BASE_URL=https://itll-happen-boyz.eventbrella.us
CLIENT_SOURCE_ID=eventbrella_ticketing

# Venue & contact
CLIENT_VENUE_NAME=TBA
CLIENT_ADDRESS_LINE1=Location To Be Announced
CLIENT_ADDRESS_LINE2=Central Florida, FL TBD
CLIENT_WEBSITE_URL=
CLIENT_CONTACT_EMAIL=info@itllhappenboyz.com
CLIENT_PHONE=321-477-9140
CLIENT_ORGANIZER_IMAGE_URL=

# --- Stripe (copy from FarmerBanks; webhook secret from scripts/create-stripe-webhook.sh) ---
STRIPE_TEST_SECRET_KEY=<copy from FarmerBanks>
STRIPE_LIVE_SECRET_KEY=<copy from FarmerBanks>
STRIPE_PUBLISHABLE_KEY=<copy from FarmerBanks>
STRIPE_WEBHOOK_TEST_SECRET=<from scripts/create-stripe-webhook.sh output>
STRIPE_WEBHOOK_LIVE_SECRET=<from scripts/create-stripe-webhook.sh --live output>
TEST_MODE=true

# --- Cloudflare Turnstile (copy from FarmerBanks) ---
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Email (to be configured by client) ---
EMAIL_FROM=noreply@eventbrella.com
EMAIL_SERVICE_API_KEY=
KLAVIYO_API_KEY=
SENDGRID_API_KEY=

# PostgreSQL (client-specific)
DATABASE_URL=postgresql://user:password@host:port/database

# AWS/DynamoDB - not used when using PostgreSQL
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=PLACEHOLDER
AWS_SECRET_ACCESS_KEY=PLACEHOLDER
TICKETS_TABLE=CLIENT_TICKETS_TABLE
EVENTS_TABLE=CLIENT_EVENTS_TABLE

# Events
CLIENT_EVENT_SLUG=
CLIENT_DEFAULT_EVENT_NAME=Summer Showcase 2026
