# ============================================
# EventBrella New Client White Lable System - Config
# ============================================
# Client-specific values below are placeholders; replace per client.
# Stripe and Klaviyo are SERVICE-LEVEL (EventBrella's)—do not template;
# they are set in deployment env and shared across clients.
# See SOP_ONBOARDING_NEW_TICKETING_CLIENT.md for client onboarding.
# ============================================

# --- Client identity (placeholders; set per client in Vercel) ---
APP_NAME=CLIENT_APP_NAME
ORGANIZER_NAME=CLIENT_ORGANIZER_NAME
BASE_URL=https://CLIENT_SUBDOMAIN.eventbrella.us
CLIENT_SOURCE_ID=eventbrella_ticketing
# Venue & contact (replace in HTML/JS or set here for API use)
CLIENT_VENUE_NAME=CLIENT_VENUE_NAME
CLIENT_ADDRESS_LINE1=CLIENT_ADDRESS_LINE1
CLIENT_ADDRESS_LINE2=CLIENT_ADDRESS_LINE2
CLIENT_WEBSITE_URL=https://CLIENT_WEBSITE_URL
CLIENT_CONTACT_EMAIL=CLIENT_CONTACT_EMAIL
CLIENT_PHONE=CLIENT_PHONE
CLIENT_ORGANIZER_IMAGE_URL=https://CLIENT_ORGANIZER_IMAGE_URL

# --- Stripe (client-agnostic: copy from FarmerBanks; only webhook secret is new per client) ---
# Copy these from FarmerBanks (same Stripe account). Webhook secret from scripts/create-stripe-webhook.sh
STRIPE_TEST_SECRET_KEY=
STRIPE_LIVE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_TEST_SECRET=
STRIPE_WEBHOOK_LIVE_SECRET=
# New clients start in test mode. Set false when going live.
TEST_MODE=true

# --- Cloudflare Turnstile (checkout bot protection; copy from FarmerBanks) ---
# Same keys as FarmerBanks; add checkout domain in Cloudflare dashboard per CLOUDFLARE_TURNSTILE_INTEGRATION.md
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Service-level: Email etc. (set in deployment) ---

# --- Service-level: Email (EventBrella if used) ---
EMAIL_FROM=noreply@eventbrella.com
EMAIL_SERVICE_API_KEY=

# PostgreSQL (client-specific; one DB per client or per env)
# From Vercel Postgres, Supabase, Railway, Neon, etc.
DATABASE_URL=postgresql://user:password@host:port/database

# AWS/DynamoDB - not used when using PostgreSQL; leave as placeholder if unused
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=PLACEHOLDER
AWS_SECRET_ACCESS_KEY=PLACEHOLDER
TICKETS_TABLE=CLIENT_TICKETS_TABLE
EVENTS_TABLE=CLIENT_EVENTS_TABLE

# Ticket pricing / capacity (examples; replace per client)
TIER_1_PRICE=10.00
TIER_2_PRICE=17.00
TIER_3_PRICE=21.00
BIWEEKLY_TOUR_CAPACITY=30
HARVEST_EVENT_CAPACITY=25
