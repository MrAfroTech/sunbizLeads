# ============================================
# ezTickets / EventBrella — Supabase & database
# ============================================
# Copy to .env (in this directory or EventBrella root) and fill in values.
# For client request flow (white-label-form + process-client-requests.js),
# set these in EventBrella/.env and in EventBrella/config.json (url + anon key only).
# ============================================

# Supabase (REST API — form submission + automation script)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
# Backend automation only (process-client-requests.js); do not expose to frontend
SUPABASE_SERVICE_KEY=your-service-role-key-here

# PostgreSQL connection (for API/tickets when using Supabase Postgres)
# From Supabase: Settings → Database → Connection string (URI)
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxx.supabase.co:5432/postgres
