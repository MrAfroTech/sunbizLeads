# ============================================
# EventBrella — example env (copy to .env)
# ============================================
# This file documents variables used across EventBrella (including ezTickets).
# Copy to .env and replace placeholders.
# ============================================

# --- Supabase (ezTickets client request flow) ---
# Form + process-client-requests.js; also copy supabaseUrl + supabaseAnonKey to config.json for the form
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# --- Cursor Agent CLI (process-client-requests.js) ---
# Required for headless/cron. Get from: https://cursor.com/dashboard → Integrations → API keys (User API Key)
# CURSOR_API_KEY=your-cursor-api-key-here

# --- Other EventBrella vars (TicketSeam, Stripe, etc.) ---
# Add other variables as needed; see existing .env for reference.
