# Trello API credentials
# Get API Key: https://trello.com/power-ups/admin → Generate a new API Key
# Get Token: After API Key, click the Token link and Allow
# Board ID: Optional until after setup_board.py runs; then add the printed board ID here
TRELLO_API_KEY=your_api_key_here
TRELLO_API_TOKEN=your_token_here
TRELLO_BOARD_ID=
