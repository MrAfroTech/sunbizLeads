PORT=8787

# Supabase (same project for API + dashboard)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Service role — webhook only; never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=
# Anon / publishable key — used by the React app (injected at build via apps/web/vite.config.js)
SUPABASE_ANON_KEY=

# Optional: override URLs for Vite if they differ from the above
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# Typeform webhook URL (production): https://fletcher-insurance.vercel.app/webhooks/typeform
# Typeform webhook signature (HMAC) — must match the secret in Typeform webhook settings
TYPEFORM_WEBHOOK_SECRET=
# Set to 1 only for local debugging (never in production)
# TYPEFORM_SKIP_SIGNATURE_VERIFY=

# Brevo transactional email (https://app.brevo.com — verify sender domain + API key)
BREVO_API_KEY=
# Must be a verified sender in Brevo
BREVO_FROM_EMAIL=
BREVO_FROM_NAME=Fletcher Insurance
# Inbox for every new Typeform submission (after successful lead save)
SALES_ALERT_EMAIL=
# Optional: copy a second address (e.g. your Gmail) to verify delivery
# SALES_ALERT_CC=

# Set to 1 so webhook JSON includes _debug.lead_id and _debug.email (sent | skipped_no_recipient | failed)
# WEBHOOK_DEBUG=
