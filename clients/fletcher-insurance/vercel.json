{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd apps/web && npm install && npm run build",
  "outputDirectory": "apps/web/dist",
  "installCommand": "cd apps/api && npm install && cd ../web && npm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/webhooks/typeform",
      "destination": "/api/webhooks/typeform"
    }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    },
    "api/webhooks/typeform.js": {
      "maxDuration": 60
    }
  }
}
