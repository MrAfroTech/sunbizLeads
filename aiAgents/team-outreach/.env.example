# Google Sheets
SHEET_ID=your_google_sheet_id_here
# Path to service account JSON (relative to team-outreach/ or absolute)
GOOGLE_CREDENTIALS_PATH=credentials/google-sheets-service-account.json

# Sender info (used when filling contact forms)
SENDER_NAME=Your Name
SENDER_EMAIL=your@email.com
SENDER_PHONE=+1234567890

# Message template. Placeholders: [TEAM_NAME], [FIRST_CONTACT]
# Use \n for newlines in a single-line value, or use actual newlines in .env
MESSAGE_TEMPLATE=Hi [FIRST_CONTACT],\n\n77% of MLB fans spend more with short lines. 45% skip long ones—costing merch & ticket sales. We partnered with the Orlando Pirates for a better fan experience & margins. 👉🏾 orlandopirates.seamlessly.us\n\nWe can do the same for the [TEAM_NAME]. Who's the best person to connect with?
