    "Send Follow-Up Email": {"main": [[{"node": "Update Opportunity", "type": "main", "index": 0}]], "error": [[{"node": "Log Error", "type": "main", "index": 0}]]},
    "Update Opportunity": {"main": [[{"node": "Log to Follow-Up Log", "type": "main", "index": 0}]]}
  },
