            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Find Podcasts": {
      "main": [
        [
          {
            "node": "Extract Podcast Info",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Extract Podcast Info": {
      "main": [
        [
          {
            "node": "Fetch Podcast Page",
