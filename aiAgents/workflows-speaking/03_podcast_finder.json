            "index": 0
          }
        ]
      ]
    },
    "Fetch Podcast Page": {
      "main": [
        [
          {
            "node": "Find Host Information",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Find Host Information": {
      "main": [
        [
          {
            "node": "Format Podcast Info",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Format Podcast Info": {
      "main": [
        [
          {
            "node": "Add to Pipeline",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "pinData": {},
