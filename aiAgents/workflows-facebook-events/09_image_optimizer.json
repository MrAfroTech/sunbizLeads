      "id": "read-events",
      "name": "Get Events Without Images",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [450, 300],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "google-sheets-cred",
          "name": "Google Sheets account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const events = $input.all();\n\nconst eventsNeedingImages = events.filter(item => {\n  const data = item.json;\n  return !data.image_url || data.image_url === '' || data.image_url === null;\n});\n\nconst classified = eventsNeedingImages.map(item => {\n  const data = item.json;\n  \n  // Determine best image strategy\n  let imageStrategy = 'generate_ai';\n  let imagePrompt = '';\n  let fallbackCategory = data.event_category || 'other';\n  \n  // Build AI image generation prompt\n  if (data.event_category === 'concert') {\n    imagePrompt = `A vibrant concert event poster for \"${data.event_name}\", featuring stage lights, crowd silhouettes, energetic atmosphere, professional event photography style, 1200x628px`;\n  } else if (data.event_category === 'sports') {\n    imagePrompt = `A dynamic sports event graphic for \"${data.event_name}\", athletic action, stadium atmosphere, bold colors, professional sports photography, 1200x628px`;\n  } else if (data.event_category === 'nightlife') {\n    imagePrompt = `A stylish nightlife event poster for \"${data.event_name}\", neon lights, dance floor energy, modern club aesthetic, vibrant colors, 1200x628px`;\n  } else if (data.event_category === 'food-festival') {\n    imagePrompt = `A mouth-watering food festival poster for \"${data.event_name}\", gourmet dishes, culinary diversity, appetizing presentation, professional food photography, 1200x628px`;\n  } else if (data.event_category === 'networking') {\n    imagePrompt = `A professional networking event graphic for \"${data.event_name}\", business professionals connecting, modern office aesthetic, clean design, 1200x628px`;\n  } else {\n    imagePrompt = `A professional event poster for \"${data.event_name}\", ${data.event_category} theme, inviting atmosphere, high quality, 1200x628px`;\n  }\n  \n  return {\n    ...data,\n    image_strategy: imageStrategy,\n    ai_image_prompt: imagePrompt,\n    fallback_category: fallbackCategory\n  };\n});\n\nreturn classified;"
      },
      "id": "classify-image-needs",
      "name": "Determine Image Strategy",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [650, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "high-value",
              "leftValue": "={{ parseInt($json.ticket_price || '0') }}",
              "rightValue": 50,
              "operator": {
                "type": "number",
                "operation": "gt"
              }
            }
          ],
          "combinator": "or"
        },
        "options": {}
      },
      "id": "check-ai-budget",
      "name": "Check AI Image Budget",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [850, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/images/generations",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{ $credentials.openAi.apiKey }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "bodyParametersJson": "={\n  \"model\": \"dall-e-3\",\n  \"prompt\": \"{{ $json.ai_image_prompt }}\",\n  \"n\": 1,\n  \"size\": \"1792x1024\",\n  \"quality\": \"standard\",\n  \"style\": \"vivid\"\n}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "id": "generate-ai-image",
      "name": "Create AI Image",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1050, 250]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $json.data[0].url }}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "file"
            }
          }
        }
      },
      "id": "download-ai-image",
      "name": "Download AI Image",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1250, 250]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://api.unsplash.com/photos/random",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "query",
              "value": "={{ $json.event_category }} event"
            },
            {
              "name": "orientation",
              "value": "landscape"
            },
