    {
      "parameters": {
        "jsCode": "const event = $input.first().json;\n\n// Pre-designed default images for each category\nconst defaultImages = {\n  'concert': 'https://your-cdn.com/defaults/concert-default.jpg',\n  'sports': 'https://your-cdn.com/defaults/sports-default.jpg',\n  'nightlife': 'https://your-cdn.com/defaults/nightlife-default.jpg',\n  'food-festival': 'https://your-cdn.com/defaults/food-default.jpg',\n  'networking': 'https://your-cdn.com/defaults/networking-default.jpg',\n  'other': 'https://your-cdn.com/defaults/generic-event.jpg'\n};\n\nconst defaultImage = defaultImages[event.fallback_category] || defaultImages['other'];\n\nreturn {\n  ...event,\n  image_url: defaultImage,\n  image_source: 'category_default',\n  image_validation_status: 'valid',\n  notes: (event.notes || '') + ' | Using category default image (validation failed)'\n};"
      },
      "id": "apply-default-image",
      "name": "Apply Default Image",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2450, 350]
    },
    {
      "parameters": {
        "operation": "update",
        "documentId": {
          "__rl": true,
          "value": "={{ $credentials.googleSheets.sheetId }}",
          "mode": "id"
        },
        "sheetName": {
          "__rl": true,
          "value": "Facebook Events Pipeline",
          "mode": "name"
        },
        "columnToMatchOn": "event_id",
        "valueToMatchOn": "={{ $json.event_id }}",
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "image_url": "={{ $json.image_url }}",
            "image_source": "={{ $json.image_source }}",
            "image_validation_status": "={{ $json.image_validation_status }}",
            "notes": "={{ $json.notes }}"
          }
        }
      },
      "id": "save-default-image",
      "name": "Save Default Image",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [2650, 350],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "google-sheets-cred",
          "name": "Google Sheets account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const allEvents = $input.all();\n\nconst summary = {\n  total_processed: allEvents.length,\n  ai_generated: allEvents.filter(e => e.image_source === 'ai_generated').length,\n  stock_photos: allEvents.filter(e => e.image_source === 'unsplash_stock').length,\n  defaults_used: allEvents.filter(e => e.image_source === 'category_default').length,\n  validation_failures: allEvents.filter(e => e.image_validation_status !== 'valid').length,\n  estimated_cost: allEvents.filter(e => e.image_source === 'ai_generated').length * 0.04,\n  timestamp: new Date().toISOString()\n};\n\nreturn summary;"
      },
      "id": "generate-report",
      "name": "Create Daily Summary",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2850, 300]
    },
    {
      "parameters": {
        "fromEmail": "noreply@seamlessly.com",
        "toEmail": "your-email@domain.com",
        "subject": "🖼️ Daily Image Generation Report",
        "text": "Image optimization summary:\n\nEvents Processed: {{ $json.total_processed }}\n\nImage Sources:\n- AI Generated (DALL-E): {{ $json.ai_generated }}\n- Stock Photos (Unsplash): {{ $json.stock_photos }}\n- Category Defaults: {{ $json.defaults_used }}\n\nValidation Failures: {{ $json.validation_failures }}\n\nEstimated Cost: ${{ $json.estimated_cost }}",
        "options": {}
      },
      "id": "send-report",
      "name": "Send Image Summary",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2.1,
      "position": [3050, 300],
      "credentials": {
        "smtp": {
          "id": "smtp-cred",
          "name": "SMTP account"
        }
      }
    }
