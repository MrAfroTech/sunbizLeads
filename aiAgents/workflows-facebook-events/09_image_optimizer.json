              "responseFormat": "json"
            }
          }
        }
      },
      "id": "fetch-stock-photo",
      "name": "Get Stock Image",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1050, 350]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $json.urls.regular }}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "file"
            }
          }
        }
      },
      "id": "download-stock-photo",
      "name": "Download Stock Image",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1250, 350]
    },
    {
      "parameters": {
        "mode": "combine",
        "combineBy": "combineAll"
      },
      "id": "merge-image-paths",
      "name": "Merge Image Paths",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 2.1,
      "position": [1450, 300]
    },
    {
      "parameters": {
        "jsCode": "const eventData = $node[\"Determine Image Strategy\"].json;\nconst imageData = $input.first();\n\n// Extract URL from AI generation or stock photo\nlet imageUrl = '';\nlet imageSource = '';\nlet imageCredit = '';\n\nif ($node[\"Download AI Image\"]?.json) {\n  // AI generated image - need to upload to CDN\n  imageSource = 'ai_generated';\n  // Note: In production, upload binary data to Cloudinary/CDN here\n  // For now, use the temporary URL (expires in 1 hour)\n  imageUrl = $node[\"Create AI Image\"].json.data[0].url;\n} else if ($node[\"Download Stock Image\"]?.json) {\n  // Stock photo - need to upload to CDN\n  imageSource = 'unsplash_stock';\n  const unsplashData = $node[\"Get Stock Image\"].json;\n  imageCredit = `Photo by ${unsplashData.user.name} on Unsplash`;\n  // Note: In production, upload binary data to Cloudinary/CDN here\n  imageUrl = unsplashData.urls.regular;\n}\n\nreturn {\n  ...eventData,\n  image_url: imageUrl,\n  image_source: imageSource,\n  image_credit: imageCredit,\n  image_generated_at: new Date().toISOString()\n};"
      },
      "id": "extract-image-url",
      "name": "Get Image URL",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1650, 300]
    },
    {
      "parameters": {
        "method": "HEAD",
        "url": "={{ $json.image_url }}",
        "options": {
          "response": {
            "response": {
              "fullResponse": true
            }
          }
        }
      },
      "id": "validate-image-url",
      "name": "Check Image Accessibility",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1850, 300]
    },
    {
      "parameters": {
        "jsCode": "const event = $input.first().json;\nconst imageResponse = $node[\"Check Image Accessibility\"];\n\n// Facebook image requirements:\n// - Min 1200x628 pixels\n// - Aspect ratio 1.91:1\n// - Max 8MB\n// - Format: JPG or PNG\n\nconst contentType = imageResponse?.json?.headers?.['content-type'] || '';\nconst contentLength = parseInt(imageResponse?.json?.headers?.['content-length'] || '0');\n\nconst isValidFormat = contentType.includes('image/jpeg') || \n                     contentType.includes('image/png') ||\n                     contentType.includes('image/jpg');\nconst isValidSize = contentLength > 0 && contentLength < 8 * 1024 * 1024; // 8MB\n\nlet validationStatus = 'valid';\nlet validationNotes = '';\n\nif (!isValidFormat && contentType) {\n  validationStatus = 'invalid_format';\n  validationNotes = 'Image must be JPG or PNG';\n} else if (!isValidSize && contentLength > 0) {\n  validationStatus = 'invalid_size';\n  validationNotes = contentLength === 0 ? 'Image not found' : 'Image too large (>8MB)';\n} else if (contentLength === 0 && !contentType) {\n  validationStatus = 'not_accessible';\n  validationNotes = 'Image URL not accessible';\n}\n\nreturn {\n  ...event,\n  image_validation_status: validationStatus,\n  image_validation_notes: validationNotes,\n  image_file_size: contentLength,\n  image_format: contentType\n};"
      },
      "id": "validate-specs",
      "name": "Validate Facebook Requirements",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2050, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "is-valid",
              "leftValue": "={{ $json.image_validation_status }}",
              "rightValue": "valid",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "check-validation",
      "name": "Check Validation Result",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [2250, 300]
    },
    {
      "parameters": {
        "operation": "update",
        "documentId": {
          "__rl": true,
          "value": "={{ $credentials.googleSheets.sheetId }}",
          "mode": "id"
        },
        "sheetName": {
          "__rl": true,
          "value": "Facebook Events Pipeline",
