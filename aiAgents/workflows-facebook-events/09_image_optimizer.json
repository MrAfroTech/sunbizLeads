        "bodyParametersJson": "={\n  \"cover_image_url\": \"{{ $json.image_url }}\",\n  \"image_source\": \"{{ $json.image_source }}\"\n}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "id": "sync-seamlessly",
      "name": "Update Seamlessly with Image",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2650, 250]
