        "url": "=https://graph.facebook.com/v18.0/{{ $json.facebook_event_id }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "fields",
              "value": "attending_count,interested_count,maybe_count,noreply_count"
            },
