      "id": "fetch-stats",
      "name": "Get Facebook Event Stats",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2650, 250]
    },
    {
      "parameters": {
        "jsCode": "const eventData = $node[\"Update to Event Imminent\"].json;\nconst fbStats = $input.first().json;\n\nconst attendingCount = fbStats.attending_count || 0;\nconst interestedCount = fbStats.interested_count || 0;\nconst maybeCount = fbStats.maybe_count || 0;\nconst totalRSVPs = attendingCount + interestedCount + maybeCount;\n\nconst ticketSales = parseInt(eventData.ticket_sales) || 0;\nconst engagementRate = ticketSales > 0 ? (totalRSVPs / ticketSales) : totalRSVPs;\n\nreturn {\n  ...eventData,\n  rsvp_count: totalRSVPs,\n  attending_count: attendingCount,\n  interested_count: interestedCount,\n  maybe_count: maybeCount,\n  facebook_engagement_rate: Math.round(engagementRate * 100) / 100\n};"
      },
      "id": "calculate-metrics",
      "name": "Aggregate Event Metrics",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2850, 250]
    },
