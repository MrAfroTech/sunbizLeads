            "status": "={{ $json.status }}",
            "posted_date": "={{ $json.posted_date }}",
            "last_activity": "={{ $json.last_activity }}",
            "notes": "={{ $json.notes }}"
          }
        }
      },
      "id": "update-status",
      "name": "Mark as Posted",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [2250, 250],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "google-sheets-cred",
          "name": "Google Sheets account"
        }
      }
