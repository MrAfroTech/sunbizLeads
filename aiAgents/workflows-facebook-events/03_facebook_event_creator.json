        }
      },
      "id": "sync-seamlessly",
      "name": "Sync Facebook Event ID to Seamlessly",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2450, 250]
    },
    {
      "parameters": {
        "fromEmail": "noreply@seamlessly.com",
        "toEmail": "your-email@domain.com",
        "subject": "✅ Facebook Event Created: {{ $json.event_name }}",
        "text": "Facebook Event successfully created!\n\nEvent: {{ $json.event_name }}\nVenue: {{ $json.venue_name }}\nDate: {{ $json.event_date }} at {{ $json.event_time }}\n\nFacebook Event: {{ $json.facebook_event_url }}\nTicket Link: {{ $json.ticket_link }}\n\nNext: Promotional post will be published shortly.",
        "options": {}
      },
      "id": "success-email",
      "name": "Confirm Event Posted",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2.1,
      "position": [2650, 250],
      "credentials": {
        "smtp": {
          "id": "smtp-cred",
          "name": "SMTP account"
        }
      }
    },
    {
      "parameters": {
        "operation": "update",
        "documentId": {
          "__rl": true,
          "value": "={{ $credentials.googleSheets.sheetId }}",
          "mode": "id"
        },
        "sheetName": {
          "__rl": true,
          "value": "Facebook Events Pipeline",
          "mode": "name"
        },
        "columnToMatchOn": "event_id",
        "valueToMatchOn": "={{ $json.event_id }}",
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "status": "API Error - Manual Review",
            "notes": "={{ $json.notes || '' }}\\nAPI Error: {{ $json.error_message }}\\nResponse: {{ $json.api_response }}"
          }
        }
      },
      "id": "log-error",
      "name": "Mark as Failed",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [1450, 350],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "google-sheets-cred",
          "name": "Google Sheets account"
        }
      }
    },
    {
      "parameters": {
        "fromEmail": "noreply@seamlessly.com",
        "toEmail": "your-email@domain.com",
        "subject": "❌ Facebook Event Creation Failed",
        "text": "Failed to create Facebook Event.\n\nEvent: {{ $json.event_name }}\nVenue: {{ $json.venue_name }}\nPage ID: {{ $json.venue_facebook_page_id }}\n\nAPI Response:\n{{ $json.api_response }}\n\nPossible issues:\n- Invalid Page Access Token\n- Page doesn't have events permission\n- API rate limit reached\n- Invalid event data\n\nReview and retry manually.",
        "options": {}
      },
      "id": "error-email",
      "name": "Alert Failed Event",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2.1,
      "position": [1650, 350],
      "credentials": {
        "smtp": {
          "id": "smtp-cred",
          "name": "SMTP account"
        }
      }
    },
    {
