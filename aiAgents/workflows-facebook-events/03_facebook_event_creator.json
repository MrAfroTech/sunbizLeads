        "sendBody": true,
        "contentType": "json",
        "bodyParametersJson": "={\n  \"facebook_event_id\": \"{{ $json.facebook_event_id }}\",\n  \"facebook_event_url\": \"{{ $json.facebook_event_url }}\",\n  \"facebook_posted\": true,\n  \"facebook_posted_date\": \"{{ $json.posted_date }}\"\n}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
