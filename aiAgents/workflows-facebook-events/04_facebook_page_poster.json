    {
      "parameters": {
        "jsCode": "const eventData = $node[\"Build Post Payload\"].json;\nconst apiResponse = $input.first().json;\n\n// Handle both success and error responses\nlet postId = '';\nlet success = false;\nlet errorMessage = '';\n\nif (apiResponse.id) {\n  postId = apiResponse.id;\n  success = true;\n} else if (apiResponse.error) {\n  errorMessage = apiResponse.error.message || JSON.stringify(apiResponse.error);\n  success = false;\n} else if (apiResponse.body?.id) {\n  postId = apiResponse.body.id;\n  success = true;\n} else if (apiResponse.body?.error) {\n  errorMessage = apiResponse.body.error.message || JSON.stringify(apiResponse.body.error);\n  success = false;\n}\n\n// Extract page ID and post ID from response (format: pageID_postID)\nconst [pageId, actualPostId] = postId.split('_');\n\nreturn {\n  ...eventData,\n  facebook_post_id: postId,\n  facebook_post_url: success ? `https://facebook.com/${postId}` : '',\n  status: success ? 'Promoted on Facebook' : 'Post Failed',\n  last_activity: new Date().toISOString(),\n  post_api_response: JSON.stringify(apiResponse),\n  error_message: errorMessage,\n  post_success: success\n};"
      },
