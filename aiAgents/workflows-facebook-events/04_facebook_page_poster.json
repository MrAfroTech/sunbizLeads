    {
      "parameters": {
        "jsCode": "const now = new Date();\nconst currentHour = now.getHours();\nconst currentDay = now.getDay();\n\n// Optimal posting times\nconst optimalTimes = {\n  weekday: [9, 12, 18, 20],\n  weekend: [11, 14, 19]\n};\n\nconst isWeekend = currentDay === 0 || currentDay === 6;\nconst idealHours = isWeekend ? optimalTimes.weekend : optimalTimes.weekday;\n\n// Find next optimal hour\nlet nextOptimalHour = idealHours.find(h => h > currentHour);\nif (!nextOptimalHour) {\n  // If no more optimal hours today, use first one tomorrow\n  nextOptimalHour = idealHours[0];\n}\n\n// Calculate wait time until next optimal hour\nconst waitUntil = new Date(now);\nwaitUntil.setHours(nextOptimalHour, 0, 0, 0);\nif (waitUntil <= now) {\n  waitUntil.setDate(waitUntil.getDate() + 1);\n}\n\nreturn {\n  wait_until: waitUntil.toISOString(),\n  wait_seconds: Math.ceil((waitUntil - now) / 1000)\n};"
      },
      "id": "calculate-wait",
      "name": "Calculate Wait Time",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1050, 350]
    },
