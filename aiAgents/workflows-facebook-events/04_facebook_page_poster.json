    {
      "parameters": {
        "jsCode": "const events = $input.all();\nconst now = new Date();\nconst currentHour = now.getHours();\nconst currentDay = now.getDay(); // 0=Sunday, 6=Saturday\n\n// Optimal posting times (higher engagement)\nconst optimalTimes = {\n  weekday: [9, 12, 18, 20], // 9am, 12pm, 6pm, 8pm\n  weekend: [11, 14, 19]     // 11am, 2pm, 7pm\n};\n\nconst isWeekend = currentDay === 0 || currentDay === 6;\nconst idealHours = isWeekend ? optimalTimes.weekend : optimalTimes.weekday;\n\n// Check if current time is optimal\nconst isOptimalTime = idealHours.includes(currentHour);\n\nconst processedEvents = events.map(item => {\n  const data = item.json;\n  \n  // Calculate urgency (how soon is event)\n  const eventDate = new Date(`${data.event_date}T${data.event_time}`);\n  const daysUntilEvent = Math.ceil((eventDate - now) / (1000 * 60 * 60 * 24));\n  \n  let urgency = 'low';\n  let shouldPostNow = isOptimalTime;\n  \n  if (daysUntilEvent <= 3) {\n    urgency = 'high';\n    shouldPostNow = true; // Post immediately if event is within 3 days\n  } else if (daysUntilEvent <= 7) {\n    urgency = 'medium';\n  }\n  \n  return {\n    ...data,\n    days_until_event: daysUntilEvent,\n    urgency: urgency,\n    should_post_now: shouldPostNow,\n    current_hour: currentHour,\n    is_optimal_time: isOptimalTime\n  };\n});\n\n// Filter to only events that should post now\nreturn processedEvents.filter(e => e.should_post_now);"
      },
      "id": "calculate-post-time",
      "name": "Calculate Best Post Time",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [650, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
