    {
      "parameters": {
        "jsCode": "const eventData = $input.first().json;\n\n// Add urgency text if event is soon\nlet urgencyText = '';\nif (eventData.days_until_event <= 3) {\n  urgencyText = `⏰ HAPPENING ${eventData.days_until_event === 0 ? 'TODAY' : \n                eventData.days_until_event === 1 ? 'TOMORROW' : \n                'IN ' + eventData.days_until_event + ' DAYS'}!\\n\\n`;\n} else if (eventData.days_until_event <= 7) {\n  urgencyText = `📅 Coming up this week!\\n\\n`;\n}\n\n// Construct full post\nconst postMessage = `${urgencyText}${eventData.page_post_copy || eventData.description || ''}\\n\\n${eventData.hashtags || ''}`;\n\n// Determine if we should include image\nconst hasImage = eventData.image_url && eventData.image_url !== '';\n\nreturn {\n  ...eventData,\n  final_post_message: postMessage,\n  has_image: hasImage,\n  post_type: hasImage ? 'photo' : 'link'\n};"
      },
