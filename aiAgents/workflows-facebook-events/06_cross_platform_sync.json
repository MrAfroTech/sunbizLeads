      "parameters": {
        "fromEmail": "noreply@seamlessly.com",
        "toEmail": "your-email@domain.com",
        "subject": "🎉 High-Performing Event: {{ $json.event_name }}",
        "text": "Event promotion is performing exceptionally well!\n\nEVENT: {{ $json.event_name }}\nVENUE: {{ $json.venue_name }}\nPERFORMANCE TIER: {{ $json.performance_tier }}\n\n📊 CROSS-PLATFORM METRICS:\n\nFacebook Event:\n- Total RSVPs: {{ $json.fb_event_rsvps }}\n- Attending: {{ $json.fb_attending }}\n- Interested: {{ $json.fb_interested }}\n\nFacebook Post:\n- Reactions: {{ $json.fb_post_reactions }}\n- Shares: {{ $json.fb_post_shares }}\n- Comments: {{ $json.fb_post_comments }}\n\nInstagram Post:\n- Impressions: {{ $json.ig_impressions }}\n- Reach: {{ $json.ig_reach }}\n- Engagement: {{ $json.ig_engagement }}\n\nTOTAL PERFORMANCE:\n- Total Reach: {{ $json.total_reach }}\n- Total Engagement: {{ $json.total_engagement }}\n- Engagement Rate: {{ $json.engagement_rate }}%\n\n🔗 LINKS:\n- Facebook Event: {{ $json.facebook_event_url }}\n- Facebook Post: {{ $json.facebook_post_url }}\n- Instagram Post: {{ $json.instagram_post_url }}\n- Tickets: {{ $json.ticket_link }}\n\nConsider: Boost top-performing posts for additional reach.",
        "options": {}
      },
