      "id": "fetch-instagram-stats",
      "name": "Get Instagram Analytics",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1250, 450]
    },
    {
      "parameters": {
        "jsCode": "const eventData = $node[\"Get Promoted Events\"].json;\nconst fbEvent = $node[\"Get FB Event Analytics\"]?.json || {};\nconst fbPost = $node[\"Get FB Post Analytics\"]?.json || {};\nconst igPost = $node[\"Get Instagram Analytics\"]?.json || {};\n\n// Extract Facebook metrics\nconst fbEventRSVPs = (fbEvent.attending_count || 0) + \n                     (fbEvent.interested_count || 0) + \n                     (fbEvent.maybe_count || 0);\n\nconst fbPostEngagement = (fbPost.shares?.count || 0) + \n                         (fbPost.reactions?.summary?.total_count || 0) + \n                         (fbPost.comments?.summary?.total_count || 0);\n\n// Extract Instagram metrics\nconst igMetrics = igPost.data || [];\nlet igImpressions = 0;\nlet igReach = 0;\nlet igEngagement = 0;\n\nigMetrics.forEach(metric => {\n  if (metric.name === 'impressions') igImpressions = metric.values?.[0]?.value || 0;\n  if (metric.name === 'reach') igReach = metric.values?.[0]?.value || 0;\n  if (metric.name === 'engagement') igEngagement = metric.values?.[0]?.value || 0;\n});\n\n// Calculate totals\nconst totalEngagement = fbPostEngagement + igEngagement;\nconst totalReach = (fbPost.reach || 0) + igReach;\n\n// Calculate engagement rate\nconst engagementRate = totalReach > 0 ? \n  parseFloat(((totalEngagement / totalReach) * 100).toFixed(2)) : 0;\n\nreturn {\n  ...eventData,\n  // Facebook metrics\n  fb_event_rsvps: fbEventRSVPs,\n  fb_attending: fbEvent.attending_count || 0,\n  fb_interested: fbEvent.interested_count || 0,\n  fb_post_shares: fbPost.shares?.count || 0,\n  fb_post_reactions: fbPost.reactions?.summary?.total_count || 0,\n  fb_post_comments: fbPost.comments?.summary?.total_count || 0,\n  \n  // Instagram metrics\n  ig_impressions: igImpressions,\n  ig_reach: igReach,\n  ig_engagement: igEngagement,\n  \n  // Aggregated metrics\n  total_engagement: totalEngagement,\n  total_reach: totalReach,\n  engagement_rate: engagementRate,\n  \n  // Performance tier\n  performance_tier: engagementRate >= 5 ? 'Excellent' :\n                   engagementRate >= 3 ? 'Good' :\n                   engagementRate >= 1 ? 'Average' : 'Poor',\n  \n  metrics_updated: new Date().toISOString()\n};"
      },
      "id": "aggregate-metrics",
      "name": "Calculate Total Performance",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1450, 450]
    },
