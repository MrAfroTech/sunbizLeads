      "id": "create-instagram-container",
      "name": "Stage Instagram Post",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1650, 250]
    },
    {
      "parameters": {
        "jsCode": "const eventData = $node[\"Format for Instagram API\"].json;\nconst apiResponse = $input.first().json;\n\n// Handle both success and error responses\nlet creationId = '';\nlet success = false;\nlet errorMessage = '';\n\nif (apiResponse.id) {\n  creationId = apiResponse.id;\n  success = true;\n} else if (apiResponse.error) {\n  errorMessage = apiResponse.error.message || JSON.stringify(apiResponse.error);\n  success = false;\n} else if (apiResponse.body?.id) {\n  creationId = apiResponse.body.id;\n  success = true;\n} else if (apiResponse.body?.error) {\n  errorMessage = apiResponse.body.error.message || JSON.stringify(apiResponse.body.error);\n  success = false;\n}\n\nreturn {\n  ...eventData,\n  instagram_creation_id: creationId,\n  instagram_container_success: success,\n  instagram_error: errorMessage\n};"
      },
      "id": "extract-creation-id",
      "name": "Get Media Container ID",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1850, 250]
