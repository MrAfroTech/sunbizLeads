    {
      "parameters": {
        "model": "gpt-4o-mini",
        "options": {
          "temperature": 0.8
        },
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "Write Instagram captions for event promotion.\n\nINSTAGRAM CAPTION RULES:\n- Hook in first 2 lines (visible before \"...more\")\n- Line breaks for readability\n- 3-5 emojis (strategic placement)\n- 5-10 hashtags (mix of branded + discovery)\n- Call-to-action in bio link reference\n- 100-150 words max\n- Conversational, not salesy\n\nSTRUCTURE:\n[Hook emoji] Attention-grabbing opening\n\n[Event details - what, when, where]\n\n[Why attend / what makes special]\n\n[CTA] Link in bio for tickets 🎟️\n\n[Hashtags]"
            },
            {
              "role": "user",
              "content": "Create Instagram caption for:\n\nEvent: {{ $json.event_name }}\nVenue: {{ $json.venue_name }}\nDate: {{ $json.event_date }} at {{ $json.event_time }}\nCategory: {{ $json.event_category }}\n\nOriginal Facebook post: {{ $json.page_post_copy || $json.description }}\n\nAdapt for Instagram - more visual, more emojis, mention \"link in bio\"\n\nReturn ONLY caption text. No JSON."
            }
          ]
        }
      },
      "id": "generate-instagram-caption",
      "name": "Write Instagram Caption",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1.3,
      "position": [1250, 250],
      "credentials": {
        "openAiApi": {
          "id": "openai-cred",
          "name": "OpenAI account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const eventData = $input.first().json;\nconst captionNode = $node[\"Write Instagram Caption\"];\nconst caption = captionNode.json.choices?.[0]?.message?.content || captionNode.json.message?.content || '';\n\nreturn {\n  ...eventData,\n  instagram_caption: caption,\n  instagram_image_url: eventData.image_url || '',\n  has_instagram_image: (eventData.image_url || '') !== ''\n};"
      },
      "id": "format-instagram-data",
      "name": "Format for Instagram API",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1450, 250]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v18.0/{{ $json.venue_instagram_id }}/media",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "image_url",
              "value": "={{ $json.instagram_image_url }}"
