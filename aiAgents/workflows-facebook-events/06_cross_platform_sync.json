    {
      "parameters": {
        "jsCode": "const events = $input.all();\n\n// Filter events that haven't been posted to Instagram yet\nconst eventsNeedingInstagram = events.filter(item => {\n  const data = item.json;\n  const instagramPosted = data.instagram_posted === true || data.instagram_posted === 'TRUE' || data.instagram_posted === true;\n  const hasInstagramId = data.venue_instagram_id && data.venue_instagram_id !== '' && data.venue_instagram_id !== null;\n  const hasImage = data.image_url && data.image_url !== '';\n  \n  return !instagramPosted && hasInstagramId && hasImage;\n});\n\nreturn eventsNeedingInstagram.map(item => item.json);"
      },
      "id": "filter-instagram-ready",
      "name": "Filter Instagram Ready Events",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [650, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "has-instagram-id",
              "leftValue": "={{ $json.venue_instagram_id }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "isNotEmpty"
              }
            },
            {
              "id": "not-null",
              "leftValue": "={{ $json.venue_instagram_id }}",
              "rightValue": null,
              "operator": {
                "type": "any",
                "operation": "notEqual"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
