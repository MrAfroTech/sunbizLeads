    {
      "parameters": {
        "jsCode": "const eventData = $node[\"Get Media Container ID\"].json;\nconst publishResponse = $input.first().json;\n\n// Handle both success and error responses\nlet instagramPostId = '';\nlet success = false;\nlet errorMessage = '';\n\nif (publishResponse.id) {\n  instagramPostId = publishResponse.id;\n  success = true;\n} else if (publishResponse.error) {\n  errorMessage = publishResponse.error.message || JSON.stringify(publishResponse.error);\n  success = false;\n} else if (publishResponse.body?.id) {\n  instagramPostId = publishResponse.body.id;\n  success = true;\n} else if (publishResponse.body?.error) {\n  errorMessage = publishResponse.body.error.message || JSON.stringify(publishResponse.body.error);\n  success = false;\n}\n\nreturn {\n  ...eventData,\n  instagram_post_id: instagramPostId,\n  instagram_post_url: success ? `https://www.instagram.com/p/${instagramPostId}/` : '',\n  instagram_posted: success,\n  instagram_posted_date: success ? new Date().toISOString() : '',\n  status: success ? 'Promoted on Facebook + Instagram' : eventData.status,\n  last_activity: new Date().toISOString(),\n  instagram_error: errorMessage || eventData.instagram_error\n};"
      },
      "id": "process-instagram-response",
      "name": "Extract Instagram Post ID",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2650, 200]
