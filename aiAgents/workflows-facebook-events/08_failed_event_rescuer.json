"id": "route-recovery",
"name": "Route Recovery Strategy",
"type": "n8n-nodes-base.switch",
"typeVersion": 3,
"position": [850, 300]
},
{
  "parameters": {
    "jsCode": "const event = $input.first().json;\nconst hoursSince = event.hours_since_failed;\n\nif (hoursSince >= 1) {\n  return {\n    ...event,\n    retry_action: 'retry_original_operation',\n    notes: (event.notes || '') + ' | Rate limit window passed, retrying'\n  };\n} else {\n  return {\n    ...event,\n    retry_action: 'wait',\n    notes: (event.notes || '') + ' | Waiting for rate limit window'\n  };\n}"
  },
