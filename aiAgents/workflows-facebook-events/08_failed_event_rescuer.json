{
  "name": "08 - Failed Event Rescuer (Auto-Recovery)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "cronExpression": "0 * * * *"
            }
          ]
        }
      },
      "id": "schedule-trigger",
      "name": "Every Hour",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [250, 300]
    },
    {
      "parameters": {
        "operation": "read",
        "documentId": {
          "__rl": true,
          "value": "={{ $credentials.googleSheets.sheetId }}",
          "mode": "id"
        },
        "sheetName": {
          "__rl": true,
          "value": "Facebook Events Pipeline",
          "mode": "name"
        },
        "options": {
          "range": "A:N"
        },
        "filters": {
          "conditions": [
            {
              "keyName": "status",
              "condition": "contains",
              "keyValue": "Failed"
            }
          ]
        }
      },
      "id": "read-failed-events",
      "name": "Get Failed Events",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [450, 300],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "google-sheets-cred",
          "name": "Google Sheets account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const failedEvents = $input.all();\n\nconst classified = failedEvents.map(item => {\n  const data = item.json;\n  const notes = (data.notes || '').toLowerCase();\n  const status = (data.status || '').toLowerCase();\n  \n  // Classify failure type\n  let failureType = 'unknown';\n  let isRecoverable = false;\n  let retryStrategy = null;\n  let priority = 'medium';\n  \n  // Rate Limit Errors\n  if (notes.includes('rate limit') || notes.includes('429')) {\n    failureType = 'rate_limit';\n    isRecoverable = true;\n    retryStrategy = 'wait_and_retry';\n    priority = 'high';\n  }\n  // Authentication Errors\n  else if (notes.includes('invalid token') || notes.includes('401') || notes.includes('403')) {\n    failureType = 'auth_error';\n    isRecoverable = true;\n    retryStrategy = 'refresh_token';\n    priority = 'critical';\n  }\n  // Image Errors\n  else if (notes.includes('image') || notes.includes('invalid url')) {\n    failureType = 'image_error';\n    isRecoverable = true;\n    retryStrategy = 'use_fallback_image';\n    priority = 'medium';\n  }\n  // Network/Timeout Errors\n  else if (notes.includes('timeout') || notes.includes('network') || notes.includes('econnrefused')) {\n    failureType = 'network_error';\n    isRecoverable = true;\n    retryStrategy = 'retry_immediately';\n    priority = 'high';\n  }\n  // Validation Errors\n  else if (notes.includes('validation') || notes.includes('policy') || notes.includes('content')) {\n    failureType = 'validation_error';\n    isRecoverable = false;\n    retryStrategy = 'manual_review';\n    priority = 'low';\n  }\n  // Duplicate Errors\n  else if (notes.includes('duplicate') || notes.includes('already exists')) {\n    failureType = 'duplicate';\n    isRecoverable = false;\n    retryStrategy = 'mark_complete';\n    priority = 'low';\n  }\n  // Event in Past\n  else if (notes.includes('past') || notes.includes('expired')) {\n    failureType = 'event_expired';\n    isRecoverable = false;\n    retryStrategy = 'archive';\n    priority = 'low';\n  }\n  \n  // Check retry count\n  const retryCount = parseInt(data.retry_count) || 0;\n  const maxRetries = 3;\n  \n  if (retryCount >= maxRetries) {\n    isRecoverable = false;\n    retryStrategy = 'escalate_to_human';\n    priority = 'critical';\n  }\n  \n  // Calculate time since failure\n  const failedAt = new Date(data.last_activity || data.posted_date || new Date());\n  const now = new Date();\n  const hoursSinceFailed = (now - failedAt) / (1000 * 60 * 60);\n  \n  // Determine if should retry now\n  let shouldRetryNow = false;\n  \n  if (failureType === 'rate_limit') {\n    shouldRetryNow = hoursSinceFailed >= 1;\n  } else if (failureType === 'network_error') {\n    shouldRetryNow = true;\n  } else if (failureType === 'auth_error') {\n    shouldRetryNow = true;\n  } else if (failureType === 'image_error') {\n    shouldRetryNow = true;\n  }\n  \n  return {\n    ...data,\n    failure_type: failureType,\n    is_recoverable: isRecoverable,\n    retry_strategy: retryStrategy,\n    retry_count: retryCount,\n    priority: priority,\n    should_retry_now: shouldRetryNow,\n    hours_since_failed: hoursSinceFailed\n  };\n});\n\nreturn classified;"
      },
      "id": "classify-failures",
      "name": "Analyze Failure Reasons",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [650, 300]
    },
    {
      "parameters": {
        "mode": "rules",
        "rules": {
          "values": [
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict"
              },
              "conditions": [
                {
                  "id": "rate-limit",
                  "leftValue": "={{ $json.failure_type }}",
                  "rightValue": "rate_limit",
                  "operator": {
                    "type": "string",
                    "operation": "equals"
                  }
                },
                {
                  "id": "should-retry",
                  "leftValue": "={{ $json.should_retry_now }}",
                  "rightValue": true,
                  "operator": {
                    "type": "boolean",
                    "operation": "true"
                  }
                }
              ],
              "combinator": "and"
            },
            "renameOutput": true,
            "outputKey": "rate_limit"
          },
          {
            "conditions": {
              "options": {
                "caseSensitive": true,
                "leftValue": "",
                "typeValidation": "strict"
            },
            "conditions": [
              {
                "id": "auth-error",
                "leftValue": "={{ $json.failure_type }}",
                "rightValue": "auth_error",
                "operator": {
                  "type": "string",
                  "operation": "equals"
                }
              }
            ],
            "combinator": "and"
          },
          "renameOutput": true,
          "outputKey": "auth_error"
        },
        {
          "conditions": {
            "options": {
              "caseSensitive": true,
              "leftValue": "",
              "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "image-error",
              "leftValue": "={{ $json.failure_type }}",
              "rightValue": "image_error",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "renameOutput": true,
        "outputKey": "image_error"
      },
      {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
        },
        "conditions": [
          {
            "id": "network-error",
            "leftValue": "={{ $json.failure_type }}",
            "rightValue": "network_error",
            "operator": {
              "type": "string",
              "operation": "equals"
            }
          }
        ],
        "combinator": "and"
      },
      "renameOutput": true,
      "outputKey": "network_error"
    },
    {
      "conditions": {
        "options": {
          "caseSensitive": true,
          "leftValue": "",
          "typeValidation": "strict"
      },
      "conditions": [
        {
          "id": "validation-error",
          "leftValue": "={{ $json.failure_type }}",
          "rightValue": "validation_error",
          "operator": {
            "type": "string",
            "operation": "equals"
          }
        }
      ],
      "combinator": "and"
    },
    "renameOutput": true,
    "outputKey": "validation_error"
  },
  {
    "conditions": {
      "options": {
        "caseSensitive": true,
        "leftValue": "",
        "typeValidation": "strict"
    },
    "conditions": [
      {
        "id": "duplicate",
        "leftValue": "={{ $json.failure_type }}",
        "rightValue": "duplicate",
        "operator": {
          "type": "string",
          "operation": "equals"
        }
      }
    ],
    "combinator": "and"
  },
  "renameOutput": true,
  "outputKey": "duplicate"
},
{
  "conditions": {
    "options": {
      "caseSensitive": true,
      "leftValue": "",
      "typeValidation": "strict"
  },
  "conditions": [
    {
      "id": "expired",
      "leftValue": "={{ $json.failure_type }}",
      "rightValue": "event_expired",
      "operator": {
        "type": "string",
        "operation": "equals"
      }
    }
  ],
  "combinator": "and"
},
"renameOutput": true,
"outputKey": "event_expired"
},
{
  "conditions": {
    "options": {
      "caseSensitive": true,
      "leftValue": "",
      "typeValidation": "strict"
  },
  "conditions": [
    {
      "id": "max-retries",
      "leftValue": "={{ $json.retry_count }}",
      "rightValue": 3,
      "operator": {
        "type": "number",
        "operation": "gte"
      }
    }
  ],
  "combinator": "and"
},
"renameOutput": true,
"outputKey": "max_retries_exceeded"
}
]
},
