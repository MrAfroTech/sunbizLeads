{
  "parameters": {
    "jsCode": "const retryResponse = $input.first().json;\nconst originalEvent = $node[\"Route Recovery Strategy\"]?.json || {};\n\n// Handle both success and error responses\nlet facebookEventId = '';\nlet success = false;\nlet errorMessage = '';\n\nif (retryResponse.id) {\n  facebookEventId = retryResponse.id;\n  success = true;\n} else if (retryResponse.error) {\n  errorMessage = retryResponse.error.message || JSON.stringify(retryResponse.error);\n  success = false;\n} else if (retryResponse.body?.id) {\n  facebookEventId = retryResponse.body.id;\n  success = true;\n} else if (retryResponse.body?.error) {\n  errorMessage = retryResponse.body.error.message || JSON.stringify(retryResponse.body.error);\n  success = false;\n}\n\nif (success) {\n  return {\n    ...originalEvent,\n    facebook_event_id: facebookEventId,\n    facebook_event_url: `https://facebook.com/events/${facebookEventId}`,\n    status: 'Facebook Event Created',\n    retry_count: (originalEvent.retry_count || 0) + 1,\n    recovered_at: new Date().toISOString(),\n    notes: (originalEvent.notes || '') + ` | Recovered successfully after ${(originalEvent.retry_count || 0) + 1} attempts`\n  };\n} else {\n  return {\n    ...originalEvent,\n    retry_count: (originalEvent.retry_count || 0) + 1,\n    status: 'Failed - Retry Unsuccessful',\n    notes: (originalEvent.notes || '') + ` | Retry attempt ${(originalEvent.retry_count || 0) + 1} failed: ${errorMessage}`\n  };\n}"
  },
  "id": "validate-recovery",
  "name": "Validate Recovery",
  "type": "n8n-nodes-base.code",
