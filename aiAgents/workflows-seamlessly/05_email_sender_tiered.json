        "toEmail": "your-email@domain.com",
        "subject": "=Email Send Failed: {{ $json.business_name }}",
        "emailType": "text",
        "message": "=Failed to send email to {{ $json.business_name }}\n\nEmail: {{ $json.email }}\nError: {{ $json.error }}\n\nReview and retry manually.",
        "options": {}
      },
      "id": "alert-failure",
