{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "trailingSlash": true,
  "rewrites": [
    { "source": "/", "destination": "/speaker/" }
  ],
  "redirects": [
    { "source": "/speaker", "destination": "/speaker/", "permanent": true }
  ]
}
