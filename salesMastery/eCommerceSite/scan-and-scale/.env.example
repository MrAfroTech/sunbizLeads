# ─── Site ───────────────────────────────────────────────────────────────────
BASE_URL=https://scan-and-scale.seamlessly.us

# Supabase (optional — site analytics)
# SUPABASE_SCAN_AND_SCALE_URL=
# SUPABASE_SCAN_AND_SCALE_ANON_KEY=

# ─── Stripe (match Vercel project env) ────────────────────────────────────
# Checkout API picks test vs live automatically:
#   production deploy  → STRIPE_LIVE_SECRET_KEY + STRIPE_WEBHOOK_LIVE_SECRET
#   preview / local    → STRIPE_TEST_SECRET_KEY + STRIPE_WEBHOOK_TEST_SECRET
# Override with TEST_MODE=false, STRIPE_TEST_MODE=true, or REACT_APP_STRIPE_ENVIRONMENT

STRIPE_LIVE_SECRET_KEY=
STRIPE_TEST_SECRET_KEY=
STRIPE_LIVE_PUBLISHABLE_KEY=

STRIPE_WEBHOOK_LIVE_SECRET=
STRIPE_WEBHOOK_TEST_SECRET=

# Stripe Connect OAuth (used by vendor flows; not required for hosted Checkout)
REACT_APP_STRIPE_REDIRECT_URI=
REACT_APP_STRIPE_SCOPE=read_write

# Optional local override (mirrors seamlesslyUs .env)
# TEST_MODE=false

# Optional: Dashboard Price ID overrides (see config/stripe-products.js)
# STRIPE_PRICE_QR_REVENUE_AUDIT=price_xxx
